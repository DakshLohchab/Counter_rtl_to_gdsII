TRACKS X 230 DO 217 STEP 460 LAYER li1 ;
TRACKS Y 170 DO 294 STEP 340 LAYER li1 ;
TRACKS X 170 DO 294 STEP 340 LAYER met1 ;
TRACKS Y 170 DO 294 STEP 340 LAYER met1 ;
TRACKS X 230 DO 217 STEP 460 LAYER met2 ;
TRACKS Y 230 DO 217 STEP 460 LAYER met2 ;
TRACKS X 340 DO 147 STEP 680 LAYER met3 ;
TRACKS Y 340 DO 147 STEP 680 LAYER met3 ;
TRACKS X 460 DO 109 STEP 920 LAYER met4 ;
TRACKS Y 460 DO 109 STEP 920 LAYER met4 ;
TRACKS X 1700 DO 29 STEP 3400 LAYER met5 ;
TRACKS Y 1700 DO 29 STEP 3400 LAYER met5 ;
COMPONENTS 10 ;
    - _06_ sky130_fd_sc_hd__xor2_2 ;
    - _07_ sky130_fd_sc_hd__a21oi_2 ;
    - _08_ sky130_fd_sc_hd__and3_2 ;
    - _09_ sky130_fd_sc_hd__nor2_2 ;
    - _10_ sky130_fd_sc_hd__xor2_2 ;
    - _11_ sky130_fd_sc_hd__inv_2 ;
    - _12_ sky130_fd_sc_hd__dfrtp_2 ;
    - _13_ sky130_fd_sc_hd__dfrtp_2 ;
    - _14_ sky130_fd_sc_hd__dfrtp_2 ;
    - _15_ sky130_fd_sc_hd__dfrtp_2 ;
END COMPONENTS
PINS 6 ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met3 ( -2000 -300 ) ( 2000 300 )
        + PLACED ( 2000 68340 ) N ;
    - count[0] + NET count[0] + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -140 -2000 ) ( 140 2000 )
        + PLACED ( 64630 2000 ) N ;
    - count[1] + NET count[1] + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -140 -2000 ) ( 140 2000 )
        + PLACED ( 230 2000 ) N ;
    - count[2] + NET count[2] + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -140 -2000 ) ( 140 2000 )
        + PLACED ( 32430 98000 ) N ;
    - count[3] + NET count[3] + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -140 -2000 ) ( 140 2000 )
        + PLACED ( 96830 98000 ) N ;
    - rst + NET rst + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met3 ( -2000 -300 ) ( 2000 300 )
        + PLACED ( 98000 30940 ) N ;
END PINS
NETS 12 ;
    - _00_ ( _12_ D ) ( _11_ Y ) + USE SIGNAL ;
    - _01_ ( _13_ D ) ( _06_ X ) + USE SIGNAL ;
    - _02_ ( _14_ D ) ( _09_ Y ) + USE SIGNAL ;
    - _03_ ( _15_ D ) ( _10_ X ) + USE SIGNAL ;
    - _04_ ( _09_ A ) ( _07_ Y ) + USE SIGNAL ;
    - _05_ ( _10_ B ) ( _09_ B ) ( _08_ X ) + USE SIGNAL ;
    - clk ( PIN clk ) ( _15_ CLK ) ( _14_ CLK ) ( _13_ CLK ) ( _12_ CLK ) + USE SIGNAL ;
    - count[0] ( PIN count[0] ) ( _12_ Q ) ( _11_ A ) ( _08_ B ) ( _07_ A2 ) ( _06_ B ) + USE SIGNAL ;
    - count[1] ( PIN count[1] ) ( _13_ Q ) ( _08_ A ) ( _07_ A1 ) ( _06_ A ) + USE SIGNAL ;
    - count[2] ( PIN count[2] ) ( _14_ Q ) ( _08_ C ) ( _07_ B1 ) + USE SIGNAL ;
    - count[3] ( PIN count[3] ) ( _15_ Q ) ( _10_ A ) + USE SIGNAL ;
    - rst ( PIN rst ) ( _15_ RESET_B ) ( _14_ RESET_B ) ( _13_ RESET_B ) ( _12_ RESET_B ) + USE SIGNAL ;
END NETS
END DESIGN
