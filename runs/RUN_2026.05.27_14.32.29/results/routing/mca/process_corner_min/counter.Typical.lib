library (counter) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 100.0;
  nom_voltage                    : 1.60;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1 ("0.00050,  0.00159,  0.00506,  0.01608,  0.05115,  0.16265,  0.51728");
  }
  type ("count") {
    base_type : array;
    data_type : bit;
    bit_width : 4;
    bit_from : 3;
    bit_to : 0;
  }

  cell ("counter") {
    pin("clk") {
      direction : input;
      capacitance : 0.0140;
    }
    pin("rst") {
      direction : input;
      capacitance : 0.0028;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.46687");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.32922");
	}
      }
    }
    bus("count") {
      bus_type : count;
      direction : output;
      capacitance : 0.0000;
    pin("count[3]") {
      direction : output;
      capacitance : 0.0013;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.47272,1.47701,1.48823,1.51562,1.58866,1.81219,2.52068");
	}
	rise_transition(template_1) {
          values("0.02224,0.02560,0.03531,0.06472,0.16191,0.48215,1.50537");
	}
	cell_fall(template_1) {
          values("1.55876,1.56269,1.57289,1.59602,1.65009,1.80248,2.28269");
	}
	fall_transition(template_1) {
          values("0.02072,0.02330,0.03049,0.04989,0.10900,0.30671,0.94749");
	}
      }
    }
    pin("count[2]") {
      direction : output;
      capacitance : 0.0010;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.50036,1.50465,1.51587,1.54325,1.61628,1.83962,2.54773");
	}
	rise_transition(template_1) {
          values("0.02229,0.02567,0.03536,0.06479,0.16194,0.48191,1.50490");
	}
	cell_fall(template_1) {
          values("1.58043,1.58437,1.59461,1.61773,1.67178,1.82418,2.30443");
	}
	fall_transition(template_1) {
          values("0.02072,0.02328,0.03049,0.04989,0.10898,0.30672,0.94756");
	}
      }
    }
    pin("count[1]") {
      direction : output;
      capacitance : 0.0013;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.54363,1.54799,1.55936,1.58687,1.65997,1.88327,2.59235");
	}
	rise_transition(template_1) {
          values("0.02301,0.02633,0.03594,0.06514,0.16199,0.48194,1.50504");
	}
	cell_fall(template_1) {
          values("1.61452,1.61847,1.62878,1.65188,1.70590,1.85834,2.33863");
	}
	fall_transition(template_1) {
          values("0.02071,0.02326,0.03050,0.04990,0.10896,0.30673,0.94765");
	}
      }
    }
    pin("count[0]") {
      direction : output;
      capacitance : 0.0008;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.56323,1.56763,1.57908,1.60667,1.67981,1.90309,2.61271");
	}
	rise_transition(template_1) {
          values("0.02342,0.02670,0.03627,0.06534,0.16201,0.48196,1.50512");
	}
	cell_fall(template_1) {
          values("1.62681,1.63077,1.64111,1.66420,1.71821,1.87066,2.35097");
	}
	fall_transition(template_1) {
          values("0.02071,0.02325,0.03050,0.04990,0.10894,0.30673,0.94769");
	}
      }
    }
    }
  }

}
